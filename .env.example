# Copy file này thành .env và điền giá trị thích hợp
# Do NOT commit file .env lên git

# CORS proxy để fetch ảnh từ YGOPRODeck (production)
# Dùng Cloudflare Worker trong cf-worker/
# Sau khi deploy worker, thay <worker-name>.<subdomain> bằng URL thực tế
# Xem: cf-worker/README.md để biết cách deploy
VITE_YGOPRO_IMAGE_PROXY_URL="https://yugioh-image-proxy.<your-subdomain>.workers.dev/?url={url}"

# Base URL của YGOPRODeck card info API (production)
VITE_YGOPRO_API_BASE="https://db.ygoprodeck.com/api/v7/cardinfo.php"
